          "content": {
            "size": 6290,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"en\" data-version=\"35.108381843\" data-app-mode=\"golang-static-spa\">\n\n<head>\n    \n    <meta charset=\"UTF-8\">\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"https://static.datadoghq.com/static/favicon.ico\">\n    <link rel=\"apple-touch-icon-precomposed\" href=\"https://static.datadoghq.com/static/apple-touch-icon-precomposed.png\">\n    <link rel=\"dns-prefetch\" href=\"https://fonts.gstatic.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com/\" crossorigin=\"anonymous\">\n    <link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Roboto+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap\">\n    <link crossorigin=\"anonymous\" href=\"https://static.datadoghq.com/static/v/35.108381843/js/spa-rspack-layered.min.css\"  rel=\"stylesheet\" type=\"text/css\" />\n    <link rel=\"preload\" as=\"script\" crossorigin=\"anonymous\" href=\"https://static.datadoghq.com/static/v/35.108381843/js/polyfills-rspack-layered.min.js\" nonce=\"vus3F7eu\"/>\n    <link rel=\"preload\" as=\"script\" crossorigin=\"anonymous\" href=\"https://static.datadoghq.com/static/v/35.108381843/js/spa-rspack-layered.min.js\" nonce=\"vus3F7eu\"/>\n    <link rel=\"preload\" as=\"fetch\" crossorigin=\"anonymous\" href=\"/config\" >\n    <link rel=\"preload\" as=\"fetch\" crossorigin=\"anonymous\" href=\"/api/v1/legacy_current_user\" >\n\n\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <style>\n        @viewport {\n            width: device-width;\n            initial-scale: 1;\n        }\n\n        body.dark-mode {\n            background-color: #222126;\n        }\n    </style>\n</head>\n\n<body>\n    \n    <script nonce=\"vus3F7eu\">\n        const addScript = url => {\n            const script = document.createElement('script');\n            script.setAttribute('crossorigin', 'anonymous'); // `.crossorigin` = doesn't set `crossorigin` in the HTML\n            script.type = 'text/javascript';\n            script.src = url;\n            script.async = false;\n            document.body.appendChild(script);\n        };\n\n\n        const addField = (name, value) => {\n            const el = document.createElement('input');\n            el.type = 'hidden';\n            el.name = name;\n            el.id = name;\n            el.value = value;\n            document.body.appendChild(el);\n        };\n\n        const error = {\n            type: 'error'\n        };\n        \n        // the browser can serve the cached config from an unlogged tab (/config endpoint already hit)\n        // this is fixed by re-fetching the config explicitely without cache\n        const headers = new Headers();\n        headers.append('pragma', 'no-cache');\n        headers.append('cache-control', 'no-cache');\n\n        Promise.all([\n            fetch('/config', {\n                    method: 'GET',\n                    headers\n                })\n                .then(res => res.json())\n                .catch(() => Promise.resolve({ featured_flags: [], permissions: {} })),\n            fetch('/api/ui/feature-flags/get-active-feature-flags', {\n                method: 'GET',\n                headers\n            })\n                .then(res => res.json())\n                .catch(() => Promise.resolve({ active_feature_flags: [], user_status: \"not-logged-in\" })),\n            fetch('/api/v1/legacy_current_user')\n                .then(res => res.json())\n                .catch(() => Promise.resolve(error)),\n        ])\n            .then(([config, featureFlags, user]) => {\n                try {\n                    const lastUserId = sessionStorage.getItem('user_id');\n                    const currentUserId = user.id.toString();\n                    sessionStorage.setItem('user_id', currentUserId);\n\n                    if (lastUserId !== null && currentUserId !== lastUserId) {\n                        return Promise.all([\n                            fetch('/config', {\n                                method: 'GET',\n                                headers\n                            })\n                                .then(res => res.json())\n                                .catch(() => Promise.resolve({ featured_flags: [], permissions: {} })),\n                            fetch('/api/ui/feature-flags/get-active-feature-flags', {\n                                method: 'GET',\n                                headers\n                            })\n                                .then(res => res.json())\n                                .catch(() => Promise.resolve({ active_feature_flags: [], user_status: \"not-logged-in\" })),\n                        ]).then(([newConfig, newFeatureFlags]) => [newConfig, newFeatureFlags, user])\n                    }\n                } catch {\n                    return [config, featureFlags, user];\n                }\n\n                return [config, featureFlags, user];\n            })\n            .then(([config, featureFlags, user]) => {\n                addField(\n                    '_authentication_token',\n                    user && user.csrf_token ? user.csrf_token : ''\n                );\n                addField('config-init', JSON.stringify(config));\n                addField('feature-flags-init', JSON.stringify(featureFlags));\n                addField('_current_user_json', user ? JSON.stringify(user) : '');\n\n                window.DD_version = '35.108381843';\n                addScript('https://static.datadoghq.com/static/v/35.108381843/js/polyfills-rspack-layered.min.js');\n                addScript('https://static.datadoghq.com/static/v/35.108381843/js/spa-rspack-layered.min.js');\n            });\n\n    </script>\n    <script nonce=\"vus3F7eu\">\n        /*\n        This checks if the system mode is selected\n        and if the user has their computer in dark-mode.\n        If so, it will add the className `.dark-mode` to the body\n        */\n        try {\n            if (\n                document.cookie.includes('datadog-theme=dark') ||\n                (\n                    document.cookie.includes('datadog-theme=system') &&\n                    matchMedia('(prefers-color-scheme: dark)').matches\n                )\n            ) {\n                document.body.classList.add('dark-mode');\n            }\n        } catch (e) { }\n    </script>\n\n    <input id=\"public-path\" name=\"public-path\" type=\"hidden\" value=\"&#34;https://static.datadoghq.com&#34;\" />\n</body>\n</html>\n"
          },
